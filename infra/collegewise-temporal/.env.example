# =============================================================================
# Temporal
# =============================================================================
TEMPORAL_MYSQL_ROOT_PASSWORD=temporal
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=collegewise-payments

# =============================================================================
# Magento MySQL (payment data — read/write)
# =============================================================================
CW_MYSQL_HOST=host.docker.internal
CW_MYSQL_PORT=3306
CW_MYSQL_USER=collegewise_app
CW_MYSQL_PASSWORD=your_password_here
CW_MYSQL_DATABASE=collegewise

# =============================================================================
# Magento REST API (Magento owns payments, notifications, and templates)
# =============================================================================
CW_MAGENTO_API_URL=https://collegewise.com
CW_MAGENTO_API_TOKEN=your_magento_integration_token
