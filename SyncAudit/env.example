# SyncAudit Configuration
# Copy to .env and fill in values (never commit .env)

# Database
# Local: SQLite (default)
DATABASE_URL=sqlite:///./sync_audit.db

# Production (Railway PostgreSQL):
# DATABASE_URL=postgresql://user:pass@host:5432/syncaudit

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_KEY=your-secret-api-key-here

# CORS - comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8501

# Dashboard
STREAMLIT_PORT=8501

# External Systems (for verification)
# APDriving - Acuity
ACUITY_USER_ID=
ACUITY_API_KEY=

# Add other project credentials as needed
# LCP - Shopify
# SHOPIFY_API_KEY=
# SHOPIFY_API_SECRET=
