# Orchestrator Configuration
# Copy this to .env and fill in your values

# =============================================================================
# LLM Provider (required - at least one)
# =============================================================================
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Default model
DEFAULT_MODEL=claude-opus-4-20250514

# Safety settings
REQUIRE_APPROVAL=true

# =============================================================================
# Harvest Time Tracking
# =============================================================================
HARVEST_ACCESS_TOKEN=your_harvest_token_here
HARVEST_ACCOUNT_ID=your_account_id_here

# =============================================================================
# Airtable (Ticket Management)
# =============================================================================
AIRTABLE_BASE_ID=your_base_id_here
AIRTABLE_TABLE_ID=your_table_id_here
AIRTABLE_PERSONAL_ACCESS_TOKEN=your_airtable_token_here

# =============================================================================
# Upwork Sync
# =============================================================================
UPWORK_SYNC_URL=http://localhost:8080

# =============================================================================
# Zendesk
# =============================================================================
ZENDESK_SUBDOMAIN=your_subdomain
ZENDESK_EMAIL=your_email@example.com
ZENDESK_API_TOKEN=your_zendesk_token_here

# =============================================================================
# ClickUp
# =============================================================================
CLICKUP_API_TOKEN=your_clickup_token_here

# =============================================================================
# DevOps Root
# =============================================================================
DEVOPS_ROOT=${HOME}/Agent007/DevOps
