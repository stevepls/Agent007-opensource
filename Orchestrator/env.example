# Orchestrator Configuration
# Copy to .env and fill in (never commit .env)

# =============================================================================
# LLM Provider (pick one or both)
# =============================================================================
ANTHROPIC_API_KEY=your-anthropic-key
OPENAI_API_KEY=your-openai-key

# Default model (Claude Opus 4 for maximum capability)
DEFAULT_MODEL=claude-opus-4-20250514

# =============================================================================
# Safety Settings
# =============================================================================
# Require human approval for file writes
REQUIRE_APPROVAL=true

# =============================================================================
# Google APIs (Gmail & Drive)
# =============================================================================
# Download OAuth credentials from Google Cloud Console
# Place at: ~/.config/agent007/google/credentials.json
# Tokens are saved automatically after first auth
GOOGLE_CONFIG_DIR=~/.config/agent007/google

# =============================================================================
# Slack
# =============================================================================
# Create a Slack app and get bot token
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
# Optional: user token for user-level actions
SLACK_USER_TOKEN=xoxp-your-slack-user-token

# =============================================================================
# Text Quality (LanguageTool)
# =============================================================================
# Free tier: 20 requests/min
# Self-hosted: Run your own LanguageTool server
LANGUAGETOOL_API_URL=https://api.languagetool.org/v2
# Optional: Premium API key for higher limits
LANGUAGETOOL_API_KEY=

# =============================================================================
# Harvest Time Tracking (optional)
# =============================================================================
HARVEST_ACCESS_TOKEN=your-harvest-token
HARVEST_ACCOUNT_ID=your-account-id
HARVEST_DEFAULT_PROJECT_ID=123456
HARVEST_DEFAULT_TASK_ID=789012

# =============================================================================
# Upwork Sync (optional)
# =============================================================================
UPWORK_SYNC_URL=http://localhost:8080

# =============================================================================
# Zendesk (Ticket Management)
# =============================================================================
# Get API token from: Admin > Channels > API
ZENDESK_EMAIL=your-email@example.com
ZENDESK_API_TOKEN=your-zendesk-api-token
ZENDESK_SUBDOMAIN=your-subdomain

# =============================================================================
# ClickUp (Project Management)
# =============================================================================
# Get API token from: Settings > Apps > API Token
CLICKUP_API_TOKEN=pk_your-clickup-api-token
