# Orchestrator Configuration
# Copy to .env and fill in (never commit .env)

# LLM Provider (pick one or both)
ANTHROPIC_API_KEY=your-anthropic-key
OPENAI_API_KEY=your-openai-key

# Default model (Claude Opus 4 for maximum capability)
# Options:
#   claude-opus-4-20250514   - Most capable, best for complex orchestration
#   claude-sonnet-4-20250514 - Fast, great for most tasks
#   gpt-4-turbo              - OpenAI alternative
DEFAULT_MODEL=claude-opus-4-20250514

# Workspace root (where agents can read/write)
WORKSPACE_ROOT=/home/steve/Agent007

# Safety: require human approval for file writes
REQUIRE_APPROVAL=true

# Harvest Time Tracking (optional)
HARVEST_ACCESS_TOKEN=your-harvest-token
HARVEST_ACCOUNT_ID=your-account-id
HARVEST_DEFAULT_PROJECT_ID=123456
HARVEST_DEFAULT_TASK_ID=789012
