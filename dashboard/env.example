# Agent007 Dashboard Environment Configuration

# Orchestrator API URL (FastAPI backend)
ORCHESTRATOR_API_URL=http://localhost:8502

# Anthropic API Key (fallback when orchestrator is unavailable)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API Key (for Whisper transcription and fallback)
OPENAI_API_KEY=sk-proj-...

# Optional: Custom port for Next.js
PORT=3000

# ── Local Development ─────────────────────────────────────────
# Skip Google OAuth for local development (set to "true" to bypass)
BYPASS_AUTH=true

# Service API key for dashboard → orchestrator calls
# Must match SERVICE_API_KEY in Orchestrator/.env (if set)
SERVICE_API_KEY=
SESSION_SECRET_KEY=
